#!/usr/bin/env bash
#MISE description="Run plugin tests - install and execute tool"
set -euo pipefail

mise plugin link --force goreleaser .
mise cache clear
mise install goreleaser@2.14.3

# Capture and display the output while also verifying it
output=$(mise exec "goreleaser@2.14.3" -- "goreleaser" --version)
echo "goreleaser output: ${output}"

if echo "${output}" | grep -q '2.14.3'; then
  echo "✓ Tests passed"
else
  echo "✗ Test failed: expected version goreleaser@2.14.3"
  exit 1
fi
